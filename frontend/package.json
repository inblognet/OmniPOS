{
  "name": "omnipos",
  "private": true,
  "version": "1.0.5",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:start": "electron .",
    "electron:build": "npm run build && electron-builder",
    "electron:publish": "npm run build && electron-builder --publish always"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^1.9.5",
    "@types/papaparse": "^5.5.2",
    "axios": "^1.13.5",
    "better-sqlite3": "^12.8.0",
    "clsx": "^2.0.0",
    "dexie": "^3.2.4",
    "dexie-react-hooks": "^1.1.6",
    "electron-updater": "^6.8.3",
    "file-saver": "^2.0.5",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.1.0",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.263.1",
    "papaparse": "^5.5.3",
    "qrcode.react": "^4.2.0",
    "react": "^18.2.0",
    "react-barcode": "^1.6.1",
    "react-dom": "^18.2.0",
    "react-qr-code": "^2.0.18",
    "react-redux": "^8.1.2",
    "react-router-dom": "^6.15.0",
    "recharts": "^3.7.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@types/file-saver": "^2.0.7",
    "@types/react": "^18.2.15",
    "@types/react-dom": "^18.2.7",
    "@vitejs/plugin-react": "^4.0.3",
    "autoprefixer": "^10.4.14",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "postcss": "^8.4.27",
    "tailwindcss": "^3.3.3",
    "typescript": "^5.0.2",
    "vite": "^4.4.5",
    "vite-plugin-electron": "^0.29.0"
  },
  "build": {
    "appId": "com.omnipos.app",
    "productName": "OmniPOSepicGen",
    "artifactName": "OmniPOS_EpicGen_v${version}.${ext}",
    "directories": {
      "output": "release/"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "publish": [
      {
        "provider": "github",
        "owner": "inblognet",
        "repo": "OmniPOS"
      }
    ]
  }
}